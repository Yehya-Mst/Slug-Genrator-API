{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(ts|js)$": "ts-jest"
  },
  "globals": {
    "ts-jest": {
      "useESM": false
    }
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(slug-lib)/)"
  ]
}
